<!-- ==================== INLINE SCRIPT ==================== -->
<script is:inline>
(function () {
  var yearEl = document.getElementById('faq-current-year');
  if (yearEl) {
    yearEl.textContent = String(new Date().getFullYear());
  }

  /* ---- Smooth scroll for progress bar links ---- */
  document.querySelectorAll('.faq-progress__step').forEach(function (link) {
    link.addEventListener('click', function (e) {
      var targetId = link.getAttribute('href');
      if (!targetId || targetId.charAt(0) !== '#') return;
      var target = document.querySelector(targetId);
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.pushState(null, '', targetId);
      }
    });
  });

  /* ---- Highlight active step in progress bar on scroll ---- */
  var sections = document.querySelectorAll('.faq-card');
  var steps = document.querySelectorAll('.faq-progress__step');

  function getScrollOffset() {
    var header = document.querySelector('.faq-header');
    var progress = document.querySelector('.faq-progress');
    return (header ? header.offsetHeight : 0) + (progress ? progress.offsetHeight : 0) + 40;
  }

  function updateActiveStep() {
    var offset = getScrollOffset();
    var current = '';
    sections.forEach(function (section) {
      if (section.getBoundingClientRect().top <= offset) {
        current = section.id;
      }
    });
    steps.forEach(function (step) {
      var href = step.getAttribute('href');
      if (href === '#' + current) {
        step.classList.add('is-active');
      } else {
        step.classList.remove('is-active');
      }
    });
  }

  var ticking = false;
  window.addEventListener('scroll', function () {
    if (!ticking) {
      window.requestAnimationFrame(function () {
        updateActiveStep();
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });
  updateActiveStep();

  /* ---- Fade-in cards on scroll ---- */
  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });

    sections.forEach(function (section) {
      section.classList.add('faq-card--animate');
      observer.observe(section);
    });
  }

  /* ---- Video modal ---- */
  var modal = document.getElementById('faq-video-modal');
  var modalVideo = document.getElementById('faq-modal-video');
  var modalOverlay = modal ? modal.querySelector('.faq-video-modal__overlay') : null;
  var modalClose = modal ? modal.querySelector('.faq-video-modal__close') : null;

  function openModal(videoSrc) {
    if (!modal || !modalVideo) return;
    modalVideo.src = videoSrc;
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    modalVideo.play();
  }

  function closeModal() {
    if (!modal || !modalVideo) return;
    modalVideo.pause();
    modalVideo.src = '';
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.faq-card__video-container[data-video-src]').forEach(function (container) {
    container.addEventListener('click', function () {
      var src = container.getAttribute('data-video-src');
      if (src) openModal(src);
    });
  });

  if (modalOverlay) modalOverlay.addEventListener('click', closeModal);
  if (modalClose) modalClose.addEventListener('click', closeModal);

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && modal && modal.classList.contains('is-open')) {
      closeModal();
    }
  });
})();
</script>